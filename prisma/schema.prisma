// Prisma Schema for Mikias Building Materials
// Enterprise-grade authentication with hybrid RBAC/PBAC

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===========================================
// AUTH & USER MANAGEMENT
// ===========================================

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  firstName         String
  lastName          String
  passwordHash      String
  phone             String?
  companyName       String?   @map("company_name")
  isVerified        Boolean   @default(false)
  verificationToken   String?   @unique
  verificationExpiry  DateTime?
  
  // Pending Email Verification
  pendingEmail        String?   @unique
  pendingEmailToken   String?   @unique
  pendingEmailExpiry  DateTime?

  // OTP for password change
  passwordChangeOtp     String?
  passwordChangeOtpExpiry DateTime?
  passwordChangeOtpAttempts  Int     @default(0)
  passwordChangeOtpLockout   DateTime?

   // Temporary password for admin-created users
  tempPassword         String?
  tempPasswordExpiry   DateTime?
  tempPasswordSentAt   DateTime?
  mustChangePassword   Boolean   @default(false)
  createdByAdmin       Boolean   @default(false)

  // 2FA Fields
  twoFactorEnabled       Boolean   @default(false)
  twoFactorSecret        String?
  twoFactorBackupCodes   String?
  twoFactorOtp           String?
  twoFactorOtpExpiry     DateTime?
  twoFactorOtpAttempts   Int       @default(0)
  
  // Trusted Devices
  trustedDevices         TrustedDevice[]

  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?
  
  // Role Management (Primary Role)
  roleId              String?
  role                Role?     @relation(fields: [roleId], references: [id])
  
  // Additional Roles (Many-to-Many)
  userRoles           UserRole[]
  
  // Direct Permissions (PBAC override)
  directPermissions UserPermission[]
  
  // Security Features
  failedLoginAttempts  Int       @default(0)
  lockoutUntil         DateTime?
  lastLoginAt          DateTime?
  lastActivityAt       DateTime?
  refreshTokenVersion  Int       @default(0)
  
  // Sessions
  sessions          Session[]
  
  securityLogs      SecurityLog[]
  
  // Business Relations
  products          Product[]      @relation("ProductCreator")
  quoteRequests     QuoteRequest[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@map("users")
}

model UserRole {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  roleId      String   @map("role_id")
  assignedBy  String?  @map("assigned_by")
  assignedAt  DateTime @default(now()) @map("assigned_at")
  isActive    Boolean  @default(true) @map("is_active")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  
  users       User[]
  userRoles   UserRole[]
  permissions RolePermission[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("roles")
}

// ===========================================
// PERMISSION MODEL WITH CATEGORY FIELD
// ===========================================

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  resource    String
  action      String
  category    String   // Category for grouping permissions (user, product, quote, system, etc.)
  
  rolePermissions RolePermission[]
  userPermissions UserPermission[]
  
  createdAt DateTime @default(now())
  
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  grantedAt    DateTime   @default(now()) @map("granted_at")

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  isGranted    Boolean    @default(true) @map("is_granted")
  grantedAt    DateTime   @default(now()) @map("granted_at")
  grantedBy    String?    @map("granted_by")
  expiresAt    DateTime?  @map("expires_at")

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

// ===========================================
// SESSION MANAGEMENT
// ===========================================

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  sessionToken String   @unique @map("session_token")
  lastActivity DateTime @default(now()) @map("last_activity")
  expiresAt    DateTime @map("expires_at")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  deviceName   String?  @map("device_name")
  deviceType   String?  @map("device_type")
  browser      String?
  os           String?
  location     String?
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

model TrustedDevice {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId    String   @map("device_id")
  deviceName  String   @map("device_name")
  deviceType  String   @map("device_type")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  lastUsedAt  DateTime @default(now()) @map("last_used_at")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@unique([userId, deviceId])
  @@map("trusted_devices")
}

// ===========================================
// SECURITY & AUDIT
// ===========================================

model SecurityLog {
  id           String    @id @default(cuid())
  userId       String?   @map("user_id")
  action       String
  resourceType String?   @map("resource_type")
  resourceId   String?   @map("resource_id")
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  details      Json?
  success      Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("security_logs")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  action      String
  resource    String
  resourceId  String?  @map("resource_id")
  details     Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ===========================================
// PRODUCT MANAGEMENT
// ===========================================

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  shortDescription String? @map("short_description")
  category    String
  subCategory String?  @map("sub_category")
  price       Decimal? @db.Decimal(10, 2)
  unit        String?
  stockQuantity Int    @default(0) @map("stock_quantity")
  stockStatus String   @default("in_stock") @map("stock_status")
  images      Json?
  isFeatured  Boolean  @default(false) @map("is_featured")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  metaTitle   String?  @map("meta_title")
  metaDescription String? @map("meta_description")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  createdBy   String?  @map("created_by")
  updatedBy   String?  @map("updated_by")

  creator     User?    @relation("ProductCreator", fields: [createdBy], references: [id])
  quoteItems  QuoteItem[]

  @@map("products")
}

// ===========================================
// QUOTE MANAGEMENT
// ===========================================

model QuoteRequest {
  id              String   @id @default(cuid())
  trackingId      String   @unique @map("tracking_id")
  customerName    String   @map("customer_name")
  customerEmail   String   @map("customer_email")
  customerPhone   String   @map("customer_phone")
  customerCompany String?  @map("customer_company")
  subject         String
  message         String   @db.Text
  status          String   @default("pending")
  priority        String   @default("medium")
  assignedTo      String?  @map("assigned_to")
  assignedAt      DateTime? @map("assigned_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  createdBy       String?  @map("created_by")
  respondedAt     DateTime? @map("responded_at")

  customer        User?    @relation(fields: [assignedTo], references: [id])
  items           QuoteItem[]

  @@index([trackingId])
  @@index([status])
  @@index([customerEmail])
  @@map("quote_requests")
}

model QuoteItem {
  id              String   @id @default(cuid())
  quoteRequestId  String   @map("quote_request_id")
  productId       String?  @map("product_id")
  productName     String   @map("product_name")
  quantity        Int
  unit            String?
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  quoteRequest    QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  product         Product?     @relation(fields: [productId], references: [id])

  @@map("quote_items")
}

// ===========================================
// NOTIFICATIONS
// ===========================================

model Notification {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  message     String   @db.Text
  type        String   @default("info")
  link        String?
  isRead      Boolean  @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ===========================================
// SYSTEM SETTINGS
// ===========================================

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        String   @default("string")
  category    String   @default("general")
  description String?
  isEncrypted Boolean  @default(false) @map("is_encrypted")
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([category])
  @@map("system_settings")
}

model SystemAuditLog {
  id          String   @id @default(cuid())
  adminId     String   @map("admin_id")
  adminEmail  String   @map("admin_email")
  action      String
  category    String
  changes     Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([adminId, createdAt])
  @@map("system_audit_logs")
}
